# ==========================================
# CodeYun .env 示例
# ==========================================
# 说明：
# 1. 复制本文件为 `.env` 后按需修改。
# 2. `.env` 可以只写你真正需要覆盖的项，不必把所有变量都填满。
# 3. `device_id` 不再从 `.env` 读取。
#    系统会自动为当前物理机器生成稳定的 device_id，
#    并持久化到机器级 identity 文件中；以后即使切换 DATA_DIR，也会尽量复用同一个 device_id。


# ==========================================
# 基础运行配置
# ==========================================

# 运行环境：development / production / test
CODEYUN_ENV=development

# 是否输出更多调试信息
CODEYUN_DEBUG=1

# 后端监听地址与端口
CODEYUN_BACKEND_HOST=0.0.0.0
CODEYUN_BACKEND_PORT=8000

# 是否启用 OpenAPI / docs
# 生产环境通常建议关闭
CODEYUN_ENABLE_DOCS=1


# ==========================================
# 数据与持久化
# ==========================================

# 主数据目录
# 默认是 backend/data
# 建议生产环境显式配置到仓库外，例如：
# D:\home\chenkunze\data\m2603codeyun\codepc_mf
CODEYUN_DATA_DIR=D:\path\to\codeyun-data

# 机器级 identity 目录
# 这里保存当前物理机器的稳定身份信息（不是业务数据）
# 不配置时，Windows 默认在：
# C:\Users\<用户名>\AppData\Local\CodeYun
CODEYUN_MACHINE_STATE_DIR=

# 数据库连接
# 不配置时，默认使用：
# sqlite:///<CODEYUN_DATA_DIR>/codeyun.db
# 如需单独指定数据库，可填 sqlite:///... 或 postgresql://...
CODEYUN_DATABASE_URL=


# ==========================================
# 安全与用户认证
# ==========================================

# JWT / 应用密钥
# 生产环境必须改成足够随机的长字符串
CODEYUN_SECRET_KEY=change-me-to-a-secure-random-string

# JWT 算法
CODEYUN_JWT_ALGORITHM=HS256

# Access Token 有效期（分钟）
# 默认 30 天 = 43200 分钟
CODEYUN_ACCESS_TOKEN_EXPIRE_MINUTES=43200


# ==========================================
# 设备面控制（集群 / 任务 / 设备控制）
# ==========================================

# 设备控制令牌
# 为空表示关闭设备面接口：
# - /api/task/*
# - /api/device-control/*
# - /api/fs/*
# 以及相关集群管理能力
CODEYUN_DEVICE_TOKEN=change-me-to-a-long-random-token


# ==========================================
# 启动期超管引导
# ==========================================

# 启动时确保存在的超管账号
# 只有用户名和密码都设置时才会生效
CODEYUN_BOOTSTRAP_ADMIN_USERNAME=admin
CODEYUN_BOOTSTRAP_ADMIN_PASSWORD=change-me

# 是否强制把上面的超管密码重置为当前值
# 0 = 不重置
# 1 = 强制重置
CODEYUN_BOOTSTRAP_ADMIN_FORCE_RESET_PASSWORD=0


# ==========================================
# CORS
# ==========================================

# 显式允许的前端来源，多个值用逗号分隔
# 例如：
# http://localhost:5173,http://192.168.31.63:5173
CODEYUN_CORS_ORIGINS=


# ==========================================
# 项目内旧脚本 / 运维辅助配置
# ==========================================
# 下面这些不是 CodeYun 后端运行必需项，
# 主要给仓库里某些旧脚本、部署脚本、个人运维工具使用。

# 服务器连接信息
YUN_SERVER_HOST=1.2.3.4
YUN_SERVER_USER=deploy
YUN_SERVER_PASS=change-me
YUN_SERVER_PORT=22

# DSP 计算器源码路径（供个别脚本使用）
DSP_SOURCE_DIR=D:\path\to\dsp-calc
